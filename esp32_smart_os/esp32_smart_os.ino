void drawUploadAnim() {
  uint32_t now = millis();
  if (now - g_uploadAnimLast < UPLOAD_ANIM_DELAY) return;
  g_uploadAnimLast = now;
  u8g2.clearBuffer();
  u8g2.drawBitmap(48, 0, 4, 32, uploadFrames[g_uploadAnimFrame]);
  u8g2.sendBuffer();
  g_uploadAnimFrame = (g_uploadAnimFrame + 1) % UPLOAD_ANIM_COUNT;
}

// =========================================================
//  TİMELAPSE GÜÇ YÖNETİMİ
//  Bosta: WiFi kes + CPU 80MHz → ~15mA
//  Aktif: WiFi baglan + CPU 240MHz → normal guc
// =========================================================

void tlEnterLowPower() {
  if (g_tlLowPower) return;
  // WiFi modemini tamamen kapat (en buyuk guç kazanimi)
  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);
  // CPU 80MHz'e duşur (tap algilama ve I2S icin yeterli)
  setCpuFrequencyMhz(80);
  g_tlLowPower = true;
  Serial.println("TL: Dusuk guc modu → 80MHz, WiFi OFF (~15mA)");
}

void tlExitLowPower() {
  if (!g_tlLowPower) return;
  // CPU once 240MHz'e dondur (WiFi stack daha stabil olsun)
  setCpuFrequencyMhz(240);
  // WiFi yeniden baslat
  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  WiFi.begin(ssid, password);
  Serial.print("TL: Normal guc → 240MHz, WiFi baglaniyor");
  uint32_t t = millis();
  while (WiFi.status() != WL_CONNECTED && millis() - t < 12000) {
    delay(200); Serial.print(".");
    yield();
  }
  Serial.println(WiFi.status() == WL_CONNECTED ? " OK" : " HATA");
  g_tlLowPower = false;
}

void startTimelapse() {
  if (!psramAvail) {
    showStatusMsg("TL HATA", "PSRAM gerekli!");
    delay(2000); currentAppMode = MAIN_MENU; drawMainMenu(); return;
  }
  g_tlBufs  = (uint8_t**)ps_malloc(TL_BATCH_FRAMES * sizeof(uint8_t*));
  g_tlSizes = (size_t*)  ps_malloc(TL_BATCH_FRAMES * sizeof(size_t));
  if (!g_tlBufs || !g_tlSizes) {
    showStatusMsg("TL HATA", "Bellek yok!");
    delay(2000); currentAppMode = MAIN_MENU; drawMainMenu(); return;
  }
  memset(g_tlBufs,  0, TL_BATCH_FRAMES * sizeof(uint8_t*));
  memset(g_tlSizes, 0, TL_BATCH_FRAMES * sizeof(size_t));
  g_tlCount       = 0;
  g_tlTotalFrames = 0;
  g_tlLowPower    = false;
  g_tlNextShot    = millis() + 5000;  // ilk frame 5 sn sonra (hazirlik)
  g_tlOledUntil   = millis() + TL_OLED_ON_MS;
  u8g2.setPowerSave(0);
  showStatusMsg("TIMELAPSE", "2dk aralikla");
  delay(1200);
  drawTimelapseScreen();
  Serial.println("Timelapse basladi.");
}

void stopTimelapse(bool doFinalize) {
  tlExitLowPower();  // CPU 240MHz + WiFi bağlan (dusuk guçteyse)
  u8g2.setPowerSave(0);
  if (doFinalize) {
    showStatusMsg("Gonderiliyor...", "VPS isliyor...");
    bool ok = sendTlFinalize();
    showStatusMsg(ok ? "Telegram OK!" : "Gonderim Hata", "");
    delay(2000);
  }
  // PSRAM temizle
  if (g_tlBufs) {
    for (int i = 0; i < g_tlCount; i++) if (g_tlBufs[i]) free(g_tlBufs[i]);
    free(g_tlBufs); g_tlBufs = NULL;
  }
  if (g_tlSizes) { free(g_tlSizes); g_tlSizes = NULL; }
  g_tlCount = 0; g_tlTotalFrames = 0; g_tlOledUntil = 0;
  sensor_t* s = esp_camera_sensor_get();
  if (s) s->set_framesize(s, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
  currentAppMode = MAIN_MENU;
  drawMainMenu();
  Serial.println("Timelapse durduruldu.");
}

void captureTimelapseFrame() {
  if (g_tlCount >= TL_BATCH_FRAMES) return;
  u8g2.setPowerSave(0);
  char buf[24];
  snprintf(buf, sizeof(buf), "Frame #%d", g_tlTotalFrames + g_tlCount + 1);
  showStatusMsg("Cekiliyor...", buf);

  sensor_t* s = esp_camera_sensor_get();
  if (s) s->set_framesize(s, TL_FRAMESIZE);
  delay(300);  // ilk oturma süresi

  // Isınma kareleri (5x): UXGA maksimum çözünürlük → en büyük akim sıçraması.
  // 5 flush frame ile güç tüketimi yumuşak rampalanır → reset önlenir.
  for (int i = 0; i < 5; i++) {
    camera_fb_t* flush = esp_camera_fb_get();
    if (flush) esp_camera_fb_return(flush);
    delay(60);
  }

  camera_fb_t* fb = esp_camera_fb_get();
  if (fb) {
    uint8_t* mem = (uint8_t*)ps_malloc(fb->len);
    if (mem) {
      memcpy(mem, fb->buf, fb->len);
      g_tlBufs[g_tlCount]  = mem;
      g_tlSizes[g_tlCount] = fb->len;
      g_tlCount++;
      Serial.printf("TL frame #%d: %u KB\n", g_tlTotalFrames + g_tlCount, fb->len / 1024);
    } else {
      Serial.println("TL: PSRAM yetmedi, frame atlandi!");
    }
    // ÖNEMLİ: set_framesize ÖNCE (fb tutuluyken DMA duruyor), fb_return SONRA çağrılmalı.
    // Ters sırada: fb_return → DMA TL_FRAMESIZE'da başlar → set_framesize çakışır → RESET.
    if (s) {
      s->set_framesize(s, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
      delay(100);
    }
    esp_camera_fb_return(fb);
  } else {
    // fb alınamadıysa DMA çalışmıyor, yine de framesize'i geri al
    if (s) s->set_framesize(s, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
  }

  g_tlOledUntil = millis() + TL_OLED_ON_MS;
  drawTimelapseScreen();
}

bool sendTlBatch() {
  if (g_tlCount == 0) return true;
  Serial.printf("TL Batch gonderiliyor: %d frame...\n", g_tlCount);

  if (WiFi.status() != WL_CONNECTED) {
    WiFi.reconnect();
    uint32_t t = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - t < 10000) { delay(200); yield(); }
    if (WiFi.status() != WL_CONNECTED) { Serial.println("TL: WiFi yok!"); return false; }
  }

  WiFiClient client;
  bool connected = false;
  for (int a = 1; a <= 3 && !connected; a++) {
    connected = client.connect(vps_host.c_str(), vps_port);
    if (!connected) delay(600);
  }
  if (!connected) { Serial.println("TL: VPS baglantisi kurulamadi!"); return false; }

  const String boundary = "TLBATCH987";
  const String head = "--" + boundary +
    "\r\nContent-Disposition: form-data; name=\"files\"; filename=\"frame.jpg\"\r\n"
    "Content-Type: image/jpeg\r\n\r\n";
  const String tail     = "\r\n";
  const String endBound = "--" + boundary + "--\r\n";

  long totalLen = 0;
  for (int i = 0; i < g_tlCount; i++) totalLen += head.length() + g_tlSizes[i] + tail.length();
  totalLen += endBound.length();

  client.println("POST /timelapse_batch HTTP/1.1");
  client.println("Host: " + vps_host);
  client.println("Content-Type: multipart/form-data; boundary=" + boundary);
  client.print("Content-Length: "); client.println(totalLen);
  client.println("Connection: close");
  client.println();

  for (int i = 0; i < g_tlCount; i++) {
    client.print(head);
    size_t sent = 0;
    while (sent < g_tlSizes[i]) {
      size_t chunk   = min((size_t)2048, g_tlSizes[i] - sent);
      size_t written = client.write(g_tlBufs[i] + sent, chunk);
      if (written > 0) sent += written; else delay(10);
      drawUploadAnim();  // gonderim sirasinda animasyon
      yield();
    }
    client.print(tail);
  }
  client.print(endBound);

  bool ok = false;
  long start = millis();
  while ((client.connected() || client.available()) && millis() - start < 30000) {
    if (client.available()) {
      String line = client.readStringUntil('\n');
      if (line.indexOf("200 OK") >= 0) ok = true;
    }
    drawUploadAnim();  // yanit beklerken animasyon
    yield();
  }
  client.stop();

  if (ok) {
    g_tlTotalFrames += g_tlCount;
    for (int i = 0; i < g_tlCount; i++) { if (g_tlBufs[i]) { free(g_tlBufs[i]); g_tlBufs[i] = NULL; } }
    g_tlCount = 0;
    Serial.printf("TL Batch OK: toplam %d frame gonderildi.\n", g_tlTotalFrames);
  } else {
    Serial.println("TL Batch HATA!");
  }
  return ok;
}

bool sendTlFinalize() {
  // Once kalan frameleri gonder
  if (g_tlCount > 0) {
    showStatusMsg("Batch gonder...", "Bekleyin...");
    sendTlBatch();
  }
  if (g_tlTotalFrames == 0) {
    showStatusMsg("Timelapse bos", "Hic frame yok");
    delay(2000);
    return false;
  }
  if (WiFi.status() != WL_CONNECTED) {
    WiFi.reconnect();
    uint32_t t = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - t < 10000) { delay(200); yield(); }
    if (WiFi.status() != WL_CONNECTED) return false;
  }

  showStatusMsg("Finalize...", "VPS video yapiyor");
  Serial.printf("TL Finalize: %d frame → video\n", g_tlTotalFrames);

  WiFiClient client;
  if (!client.connect(vps_host.c_str(), vps_port)) return false;

  client.println("POST /timelapse_finalize HTTP/1.1");
  client.println("Host: " + vps_host);
  client.println("Content-Length: 0");
  client.println("Connection: close");
  client.println();

  bool ok = false;
  long start = millis();
  while ((client.connected() || client.available()) && millis() - start < 120000) {
    if (client.available()) {
      String line = client.readStringUntil('\n');
      if (line.indexOf("200 OK") >= 0) ok = true;
      if (line.length() > 2) Serial.println(line);
    }
    drawUploadAnim();  // FFmpeg isleme + Telegram gonderme sirasinda animasyon
    yield();
  }
  client.stop();
  Serial.printf("TL Finalize: %s\n", ok ? "OK" : "HATA");
  return ok;
}

void runTimelapse() {
  static uint32_t lastDraw = 0;
  uint32_t now = millis();

  // OLED guc yonetimi
  if (g_tlOledUntil > 0) {
    if (now > g_tlOledUntil) {
      g_tlOledUntil = 0;
      u8g2.setPowerSave(1);   // OLED kapat
      tlEnterLowPower();      // WiFi kes + CPU 80MHz → ~15mA bosta
    } else if (now - lastDraw > 500) {
      lastDraw = now;
      drawTimelapseScreen();  // 2x/sn guncelle
    }
  }

  // Frame vakti geldi mi?
  if (now < g_tlNextShot) return;

  // ── Dusuk gucten cik (CPU 240MHz + WiFi baglan) ─────────
  if (g_tlLowPower) {
    u8g2.setPowerSave(0);
    showStatusMsg("Uykudan cikiyor", "WiFi baglaniyor..");
    tlExitLowPower();
  }

  // ── Frame cek ──────────────────────────────────────────
  // Sonraki vakti ONCE ayarla: capture suresi (1-2sn) hesaba katilir
  g_tlNextShot = now + TL_INTERVAL_MS;
  captureTimelapseFrame();

  // ── Batch doldu mu? → gonder (capture'dan hemen sonra) ─
  // Bir sonraki frame TL_INTERVAL_MS (2dk) sonra — gonderim icin bol zaman var
  if (g_tlCount >= TL_BATCH_FRAMES) {
    u8g2.setPowerSave(0);
    showStatusMsg("Batch gonder...", "Lutfen bekle...");
    bool ok = sendTlBatch();
    Serial.printf("TL Batch sonucu: %s\n", ok ? "OK" : "HATA");
    g_tlOledUntil = millis() + TL_OLED_ON_MS;  // durumu goster
  }
}

