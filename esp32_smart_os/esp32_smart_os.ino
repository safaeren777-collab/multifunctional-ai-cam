//  SES KOMUTU UYGULA
//  VPS'ten gelen komut adina gore ilgili modu/aksiyonu baslat
// =========================================================
void executeVoiceCommand(const String& cmd) {
  Serial.printf("executeVoiceCommand: '%s'\n", cmd.c_str());

  if (cmd == "guard") {
    hasPrevBlock   = false;
    currentAppMode = SECURITY_MODE;
    for (int cd = 3; cd > 0; cd--) {
      char buf[24]; snprintf(buf, sizeof(buf), "Guard: %d...", cd);
      showStatusMsg(buf, "3x:Dur");
      delay(1000);
    }
    showStatusMsg("GUARD AKTIF", "");
    delay(500);
    drawSecurityScreen();
  }
  else if (cmd == "ai") {
    currentAppMode = AI_MODE;
    runAiMode();
  }
  else if (cmd == "photo") {
    classicState   = CS_VIEWFINDER;
    currentAppMode = CLASSIC_MODE;
    sensor_t* sc   = esp_camera_sensor_get();
    if (sc) sc->set_framesize(sc, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
    delay(150);
    takeClassicPhoto();
  }
  else if (cmd == "settings") {
    g_settCursor   = 0;
    currentAppMode = SETTINGS_MODE;
    drawSettingsScreen();
  }
  else if (cmd == "sleep") {
    goToSleep();
  }
  else if (cmd == "back") {
    currentAppMode = MAIN_MENU;
    drawMainMenu();
  }
  else if (cmd == "next") {
    if (currentAppMode == MAIN_MENU) {
      menuCursor = (menuCursor + 1) % MENU_ITEMS;
      drawMainMenu();
    }
  }
  else {  // unknown veya bos
    showStatusMsg("Anlasılamadı", "Tekrar deneyin");
    delay(1500);
    switch (currentAppMode) {
      case MAIN_MENU:     drawMainMenu();          break;
      case CLASSIC_MODE:  drawClassicViewfinder(); break;
      case SETTINGS_MODE: drawSettingsScreen();    break;
      case SECURITY_MODE: drawSecurityScreen();    break;
      case VOICE_MODE:    drawVoiceScreen();       break;
      default:            drawMainMenu();          break;
    }
  }
}

// =========================================================
//  SES KAYDI + GONDERME AKISI
//  1. I2S sifirla (temiz baslangic)
//  2. 2 saniye ses kaydet → PSRAM
//  3. VPS /voice_command → Gemini → komut adi
//  4. executeVoiceCommand() ile calistir
// =========================================================
void captureAndSendVoiceCommand() {
  Serial.println("Ses komutu yakalanıyor...");

  if (!psramAvail) {
    showStatusMsg("HATA", "PSRAM Gerekli!");
    delay(1500);
    drawMainMenu();
    return;
  }

  uint8_t* wavBuf = (uint8_t*)ps_malloc(VOICE_WAV_TOTAL);
  if (!wavBuf) {
    showStatusMsg("HATA", "Bellek Yok!");
    delay(1500);
    drawMainMenu();
    return;
  }

  buildWavHeader(wavBuf, VOICE_BYTES);
  memset(wavBuf + 44, 0, VOICE_BYTES);

  // I2S temiz baslangic: DMA buffer eski veri icermeyecek
  micI2S.end();
  delay(100);
  micI2S.setPinsPdmRx(42, 41);
  micI2S.begin(I2S_MODE_PDM_RX, 16000, I2S_DATA_BIT_WIDTH_16BIT, I2S_SLOT_MODE_MONO);
  delay(200);  // Kısa bekleme: komut anında söyleniyor

  // Kayit
  int16_t* pcm      = (int16_t*)(wavBuf + 44);
  int      recorded = 0;
  int16_t  rdBuf[160];

  // Ilk ekran: kayit basliyor
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_5x7_tr);
  drawTextCenter("MIC AKTIF", 8);
  drawTextCenter("Komut soyleyin", 17);
  u8g2.drawFrame(4, 23, 120, 7);
  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.sendBuffer();

  uint32_t recStart = millis();

  while (recorded < VOICE_SAMPLES) {
    int got = micI2S.readBytes((char*)rdBuf, sizeof(rdBuf));
    if (got <= 0) { delay(2); continue; }
    int toCopy = min(160, VOICE_SAMPLES - recorded);
    memcpy(pcm + recorded, rdBuf, toCopy * 2);
    recorded += toCopy;

    // Her %12.5'te ekrani guncelle (8 adim)
    if (recorded % 4000 == 0) {
      int barW = (120 * recorded) / VOICE_SAMPLES;
      int pct  = (recorded * 100) / VOICE_SAMPLES;
      u8g2.clearBuffer();
      u8g2.setFont(u8g2_font_5x7_tr);
      drawTextCenter("MIC AKTIF", 8);
      drawTextCenter("Komut soyleyin", 17);
      u8g2.drawFrame(4, 23, 120, 7);
      if (barW > 0) u8g2.drawBox(4, 23, barW, 7);
      char buf[8]; snprintf(buf, sizeof(buf), "%d%%", pct);
      drawTextCenter(buf, 31);
      u8g2.setFont(u8g2_font_6x10_tr);
      u8g2.sendBuffer();
    }
    yield();
  }
  Serial.printf("Ses kaydi tamamlandi (%d ms, %d byte)\n",
                millis() - recStart, VOICE_BYTES);

  showStatusMsg("Anlasiliyor...", "Bekleyin...");

  // I2S tap moduna geri al
  micI2S.end();
  delay(50);
  micI2S.setPinsPdmRx(42, 41);
  micI2S.begin(I2S_MODE_PDM_RX, 16000, I2S_DATA_BIT_WIDTH_16BIT, I2S_SLOT_MODE_MONO);
  for (int i = 0; i < 5; i++) { micI2S.readBytes((char*)micBuf, sizeof(micBuf)); delay(10); }

  // VPS'e gonder
  String command = sendVoiceToVPS(wavBuf, VOICE_WAV_TOTAL);
  free(wavBuf);

  Serial.printf("VPS komutu alindi: '%s'\n", command.c_str());

  if (command.length() == 0) {
    showStatusMsg("Ag Hatasi", "WiFi/VPS hata");
    delay(1800);
    switch (currentAppMode) {
      case MAIN_MENU:     drawMainMenu();          break;
      case CLASSIC_MODE:  drawClassicViewfinder(); break;
      case SETTINGS_MODE: drawSettingsScreen();    break;
      case VOICE_MODE:    drawVoiceScreen();       break;
      default:            drawMainMenu();          break;
    }
    return;
  }

  // Komutu ekranda goster
  char dispBuf[20];
  snprintf(dispBuf, sizeof(dispBuf), ">>> %s", command.c_str());
  showStatusMsg(dispBuf, "Calisiyor...");
  delay(700);

  executeVoiceCommand(command);
}

// =========================================================
//  SETUP
// =========================================================
void setup() {
  // Brownout dedektörünü devre disi birak.
  // WRITE_PERI_REG(RTC_CNTL_BROWN_OUT_REG, 0) tüm register'i sifirlar
  // → ESP32-S3+IDF v5'te bootloop. Sadece ENA bitini temizle (güvenli):
  REG_CLR_BIT(RTC_CNTL_BROWN_OUT_REG, RTC_CNTL_BROWN_OUT_ENA);

  Serial.begin(115200);
  delay(800);
  Serial.println("\n--- SMART OS v3.32 STARTING ---");

  Wire.begin(5, 6);
  u8g2.begin();
  u8g2.setFont(u8g2_font_6x10_tr);

  pinMode(BUTTON_PIN, INPUT_PULLUP);

  psramAvail = psramFound();
  maxFrames  = psramAvail ? MAX_FRAMES_PSRAM : MAX_FRAMES_RAM;
  Serial.printf("PSRAM: %s | Maks kare: %d\n", psramAvail ? "VAR" : "YOK", maxFrames);

  showStartupAnimation();

  WiFi.mode(WIFI_STA);
  WiFi.setSleep(false);
  WiFi.setAutoReconnect(true);
  WiFi.begin(ssid, password);
  Serial.print("WiFi baglaniliyor");

  // WiFi bağlanırken animasyon oynat
  // 32x32 ikon → 128x32 ekranda yatayda ortala (x=48), dikeyde tam doldur (y=0)
  {
    int wifiFrame = 0;
    uint32_t wStart = millis();
    uint32_t lastFrameTime = 0;
    while (WiFi.status() != WL_CONNECTED && millis() - wStart < 15000) {
      uint32_t now = millis();
      if (now - lastFrameTime >= WIFI_ANIM_DELAY) {
        lastFrameTime = now;
        u8g2.clearBuffer();
        u8g2.drawBitmap(48, 0, 4, 32, wifiFrames[wifiFrame]);
        u8g2.sendBuffer();
        wifiFrame = (wifiFrame + 1) % WIFI_ANIM_COUNT;
        Serial.print(".");
      }
      yield();
    }
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.printf("\nWiFi OK: %s\n", WiFi.localIP().toString().c_str());
    showStatusMsg("WiFi OK!", WiFi.localIP().toString().c_str());
    delay(800);
  } else {
    Serial.println("\nWiFi BASARISIZ - Offline mod.");
    showStatusMsg("WiFi FAILED", "Offline mode");
    delay(1500);
  }

  if (!initCamera()) {
    // v3.31: Detayli tani ekrani — Serial Monitor olmadan da gorulebilir
    // 3 satir: CAM FAIL  /  ERR 0x???  /  PSRAM: VAR or YOK
    u8g2.clearBuffer();
    u8g2.setFont(u8g2_font_6x10_tr);
    drawTextCenter("CAM INIT FAIL", 9);

    char errBuf[24];
    snprintf(errBuf, sizeof(errBuf), "ERR 0x%X",
             (unsigned)g_camInitError);
    drawTextCenter(errBuf, 19);

    char psramBuf[24];
    snprintf(psramBuf, sizeof(psramBuf), "PSRAM:%s",
             psramAvail ? "VAR" : "YOK");
    u8g2.setFont(u8g2_font_5x7_tr);
    drawTextCenter(psramBuf, 30);
    u8g2.setFont(u8g2_font_6x10_tr);
    u8g2.sendBuffer();

    delay(8000);   // Kullaniciya okuma suresi ver
  }

  initMic();

  // USB HID Klavye — IT Support modu için
  // Serial (UART0) bu başlatma ile çakışmaz
  g_HIDKbd.begin();
  USB.begin();

  lastInteraction = millis();
  drawMainMenu();
}

// =========================================================
//  MOD GEÇİŞ ANİMASYONU (non-blocking)
// =========================================================

// Geçişi başlatır — çağırınca loop() animasyonu kendi yürütür
void startModeTransition(AppMode next) {
  g_transNext   = next;
  g_transActive = true;
  g_transFrame  = 0;
  g_transLastMs = 0;
  u8g2.setPowerSave(0);
  // Mevcut ekran içeriğini snapshot al (slide-wipe için kaynak)
  uint8_t* live = u8g2.getBufferPtr();
  if (live) memcpy(g_transSnapBuf, live, 512);
  else      memset(g_transSnapBuf, 0, 512);
}

// Slide-wipe geçiş animasyonu — her loop() çağrısında 1 adım işler
// 8 adım × 10ms = 80ms toplam | non-blocking | sıfır delay
// Mekanizma: snapshot buffer'ı sola kaydırarak ekrandan uçurur
// Geri dönüş: true = animasyon bitti → initMode() çağır
bool tickModeTransition() {
  uint32_t now = millis();
  if (now - g_transLastMs < TRANS_SLIDE_MS) return false;
  g_transLastMs = now;

  // 128px ekranı 8 adımda tamamen sola kaydır (adım başı 16px)
  // g_transFrame: 0→7 (adım 1→8), her adımda toplam offset = (frame+1)*16
  int shift = (g_transFrame + 1) * 16;  // 16, 32, 48, 64, 80, 96, 112, 128

  uint8_t* dst = u8g2.getBufferPtr();
  if (dst) {
    // 128×32 OLED = 4 sayfa × 128 sütun (her byte = 8 dikey piksel)
    for (int page = 0; page < 4; page++) {
      uint8_t* srcRow = g_transSnapBuf + page * 128;
      uint8_t* dstRow = dst            + page * 128;
      int remain = 128 - shift;
      if (remain > 0) memcpy(dstRow, srcRow + shift, remain);
      if (shift  > 0) memset(dstRow + (remain > 0 ? remain : 0), 0,
                             (shift < 128 ? shift : 128));
    }
    u8g2.sendBuffer();
  }

  if (++g_transFrame >= TRANS_SLIDE_STEPS) {
    g_transActive = false;
    return true;   // animasyon tamamlandı → initMode() çağrılacak
  }
  return false;
}

// Animasyon bittikten sonra hedef modu başlatır
void initMode(AppMode mode) {
  currentAppMode = mode;
  switch (mode) {

    case MAIN_MENU:
      drawMainMenu();
      break;

    case SECURITY_MODE: {
      hasPrevBlock = false;
      for (int cd = 5; cd > 0; cd--) {
        char cdBuf[20];
        snprintf(cdBuf, sizeof(cdBuf), "Starting in %d...", cd);
        showStatusMsg("GUARD MODE", cdBuf);
        delay(1000);
      }
      showStatusMsg("GUARD MODE", "ACTIVE!");
      delay(500);
      drawSecurityScreen();
      break;
    }

    case AI_MODE:
      runAiMode();
      break;

    case CLASSIC_MODE: {
      classicState = CS_VIEWFINDER;
      sensor_t* sc = esp_camera_sensor_get();
      if (sc) sc->set_framesize(sc, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
      delay(150);
      drawClassicViewfinder();
      break;
    }

    case VOICE_MODE:
      drawVoiceScreen();
      break;

    case TIMELAPSE_MODE:
      startTimelapse();
      break;

    case SETTINGS_MODE:
      g_settCursor = 0;
      drawSettingsScreen();
      break;

    case IT_MODE:
      // State machine'i sifirla - runItMode() bir sonraki loop'ta register dener
      g_itRegistered            = false;
      g_itState                 = IT_S_NEED_REGISTER;
      g_itLastRegisterAttemptMs = 0;
      g_itLastPollMs            = 0;
      g_itRegisterRetryCount    = 0;
      g_itPendingCmdType        = "";
      drawItScreen();
      // NOT: itRegisterVPS() artik blocking sekilde burada cagrilmiyor.
      // runItMode() ilk loop iterasyonunda register denemesi yapacak.
      // Bu sayede 3x tap cikis garantili — registration sirasinda bile tap yakalanir.
      break;

    default:
      currentAppMode = MAIN_MENU;
      drawMainMenu();
      break;
  }
}

// =========================================================
//  ANA DONGU
// =========================================================
void loop() {
  uint32_t now = millis();

  // Mod geçiş animasyonu — en yüksek öncelik, non-blocking (22ms/kare)
  if (g_transActive) {
    checkTap();  // tap'ları absorbe et, işleme
    if (tickModeTransition()) initMode(g_transNext);
    return;
  }

  if (currentAppMode == MAIN_MENU) reconnectWiFiIfNeeded();

  // Ekran koruyucu
  if (currentAppMode == MAIN_MENU && !isScreenSaver && (now - lastInteraction > SCREEN_SAVER_MS)) {
    u8g2.setPowerSave(1);
    isScreenSaver = true;
  }

  // Otomatik kilit: 40sn tap olmazsa kilitle
  if (tapActive && now - lastTapActivity > TAP_LOCK_MS) {
    tapActive = false;
    Serial.println("Tap: Otomatik kilit aktif.");
  }

  int tapCount = checkTap();

  if (tapCount > 0) {
    if (!tapActive) {
      // KİLİTLİ: sadece 3 tap kilit acar
      if (tapCount == 3) {
        tapActive       = true;
        lastTapActivity = now;
        lastInteraction = now;
        if (isScreenSaver) {
          isScreenSaver = false;
          u8g2.setPowerSave(0);
        }
        showStatusMsg("TAP AKTIF", "3x ile kilit");
        delay(600);
        drawMainMenu();
      }
      // 1 veya 2 tap kilitliyken: tamamen yoksay
      return;
    }

    // AÇIK: normal komutlar
    lastTapActivity = now;
    lastInteraction = now;

    if (isScreenSaver) {
      isScreenSaver = false;
      u8g2.setPowerSave(0);
      drawMainMenu();
      return;
    }

    // Guard ve Timelapse modda sadece 3x tap geçerli → durdur/çık
    if (currentAppMode == SECURITY_MODE) {
      if (tapCount == 3) {
        guardCleanup();
        sensor_t* sg = esp_camera_sensor_get();
        if (sg) sg->set_framesize(sg, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
        startModeTransition(MAIN_MENU);
      }
      // 1x veya 2x tap guard modda tamamen yoksayılır
      return;
    }
    if (currentAppMode == TIMELAPSE_MODE) {
      if (tapCount == 3) {
        stopTimelapse(true);   // kalan frameleri gönder + video + Telegram + çık
      }
      // 1x veya 2x tap timelapse modda tamamen yoksayılır
      return;
    }
    if (currentAppMode == IT_MODE) {
      if (tapCount == 3) {
        g_itRegistered = false;
        startModeTransition(MAIN_MENU);
      }
      // 1x veya 2x tap IT modda yoksayılır (yanlışlıkla script tetiklenmesin)
      return;
    }

    if      (tapCount == 1) handleSingleTap();   // 1 tap = navigate/aksiyon
    else if (tapCount == 2) handleDoubleTap();   // 2 tap = gir/onayla
    return;
  }

  // Tap flash goselini 200ms sonra temizle
  if (g_tapFlash > 0 && now - g_tapFlash >= 200 && now - g_tapFlash < 300) {
    g_tapFlash = 0;
    switch (currentAppMode) {
      case MAIN_MENU:     if (!isScreenSaver) drawMainMenu(); break;
      case CLASSIC_MODE:
        if (classicState == CS_VIEWFINDER) drawClassicViewfinder();
        else                               drawClassicDone();
        break;
      case SETTINGS_MODE: drawSettingsScreen(); break;
      case SECURITY_MODE: drawSecurityScreen(); break;
      case RESULT_VIEW:   renderAiPage();       break;
      case VOICE_MODE:    drawVoiceScreen();    break;
      case TIMELAPSE_MODE:
        if (g_tlOledUntil > 0) drawTimelapseScreen();
        break;
      default: break;
    }
  }

  if (currentAppMode == SECURITY_MODE)  runSecurityMode();
  if (currentAppMode == TIMELAPSE_MODE) runTimelapse();
  if (currentAppMode == IT_MODE)        runItMode();
}

// =========================================================
//  TEK TAP AKSIYONU
// =========================================================
void handleSingleTap() {
  g_tapFlash      = millis();
  lastInteraction = millis();

  switch (currentAppMode) {
    case MAIN_MENU:
      menuCursor = (menuCursor + 1) % MENU_ITEMS;
      drawMainMenu();
      break;

    case RESULT_VIEW: {
      int totalPages = max(1, (g_aiLineCount + 3) / 4);
      if (g_aiPage < totalPages - 1) {
        g_aiPage++;
        renderAiPage();
      } else {
        startModeTransition(MAIN_MENU);
      }
      break;
    }

    case CLASSIC_MODE:
      if (classicState == CS_VIEWFINDER) takeClassicPhoto();
      else { classicState = CS_VIEWFINDER; drawClassicViewfinder(); }
      break;

    case SETTINGS_MODE:
      g_settCursor = (g_settCursor + 1) % SETT_COUNT;
      drawSettingsScreen();
      break;

    case SECURITY_MODE:
      // 1x tap guard modda yoksayılır — sadece 3x tap durdurur (loop() içinde işlenir)
      break;

    case VOICE_MODE:
      // 1x tap → dinlemeye basla
      captureAndSendVoiceCommand();
      if (currentAppMode == VOICE_MODE) drawVoiceScreen();
      break;

    case TIMELAPSE_MODE:
      // 1x tap timelapse modda yoksayılır — sadece 3x tap durdurur (loop() içinde işlenir)
      break;

    default:
      break;
  }
}

// =========================================================
//  CIFT TAP AKSIYONU
// =========================================================
void handleDoubleTap() {
  g_tapFlash      = millis();
  lastInteraction = millis();

  switch (currentAppMode) {

    case MAIN_MENU:
      switch (menuCursor) {
        case 0: // GUARD
          startModeTransition(SECURITY_MODE);
          break;
        case 1: // AI ASSIST
          startModeTransition(AI_MODE);
          break;
        case 2: // CLASSIC
          startModeTransition(CLASSIC_MODE);
          break;
        case 3: // VOICE MODE
          startModeTransition(VOICE_MODE);
          break;
        case 4: // TIMELAPSE
          startModeTransition(TIMELAPSE_MODE);
          break;
        case 5: // SETTINGS
          startModeTransition(SETTINGS_MODE);
          break;
        case 6: // IT SUPPORT
          startModeTransition(IT_MODE);
          break;
        case 7: // SLEEP
          goToSleep();
          break;
        default:
          showStatusMsg("NOT READY", "Coming soon...");
          delay(1500);
          drawMainMenu();
          break;
      }
      break;

    case SECURITY_MODE:
      // 2x tap guard modda yoksayılır — sadece 3x tap durdurur (loop() içinde işlenir)
      break;

    case RESULT_VIEW:
      startModeTransition(MAIN_MENU);
      break;

    case CLASSIC_MODE: {
      sensor_t* s2 = esp_camera_sensor_get();
      if (s2) s2->set_framesize(s2, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
      startModeTransition(MAIN_MENU);
      break;
    }

    case SETTINGS_MODE:
      activateSetting();
      break;

    case VOICE_MODE:
      // 2x tap → ana menuye don
      startModeTransition(MAIN_MENU);
      break;

    case TIMELAPSE_MODE:
      // 2x tap timelapse modda yoksayılır — sadece 3x tap durdurur (loop() içinde işlenir)
      break;

    default:
      break;
  }
}

// =========================================================
//  SETTINGS
// =========================================================

String getSettingValue(int id) {
  switch (id) {
    case SETT_PHOTO_TMR:  return g_photoTimer ? "3 sec" : "OFF";
    case SETT_GUARD_LOOP: return g_guardLoop  ? "LOOP" : "ONE-SHOT";
    case SETT_BACK:       return "-> Main";
  }
  return "";
}

void activateSetting() {
  switch (g_settCursor) {
    case SETT_PHOTO_TMR:
      g_photoTimer = !g_photoTimer;
      drawSettingsScreen();
      break;
    case SETT_GUARD_LOOP:
      g_guardLoop = !g_guardLoop;
      drawSettingsScreen();
      break;
    case SETT_BACK:
      g_settCursor   = 0;
      currentAppMode = MAIN_MENU;
      drawMainMenu();
      break;
  }
}

void drawSettingsScreen() {
  u8g2.clearBuffer();
  drawHeader();
  u8g2.setFont(u8g2_font_6x10_tr);
  drawTextCenter(SETT_NAMES[g_settCursor], 11);

  String val = getSettingValue(g_settCursor);
  drawTextCenter(val.c_str(), 22);

  u8g2.setFont(u8g2_font_4x6_tr);
  if (g_settCursor == SETT_BACK) drawTextCenter("1x:Skip  2x:Back", 31);
  else                           drawTextCenter("1x:Next  2x:Toggle", 31);
  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.sendBuffer();
}

// Geri sayim; true=devam, false=cift-tap ile iptal
bool runCountdown(int seconds, const char* label) {
  // Aktivasyon tapinin bitmesini bekle (kisa gecikme)
  for (int i = 0; i < 3; i++) {
    micI2S.readBytes((char*)micBuf, sizeof(micBuf));
    delay(10);
  }

  for (int i = seconds; i > 0; i--) {
    char buf[24];
    snprintf(buf, sizeof(buf), "%s in %d...", label, i);
    showStatusMsg(buf, "2x:Cancel");
    uint32_t t = millis();
    while (millis() - t < 1000) {
      int tap = checkTap();
      if (tap == 2) return false;  // cift tap = iptal
      yield();
      delay(20);
    }
  }
  return true;
}

// =========================================================
//  GUARD / GÜVENLİK MODU
// =========================================================

void guardInit() {
  sensor_t* s = esp_camera_sensor_get();
  if (!s) return;
  s->set_framesize(s, FRAMESIZE_QQVGA);
  delay(100);

  const int CAL_FRAMES   = 20;
  const int CAL_DELAY_MS = 150;

  for (int i = 0; i < CAL_FRAMES; i++) {
    camera_fb_t* f = esp_camera_fb_get();
    if (f) esp_camera_fb_return(f);

    if (i % 5 == 0) {
      int pct  = (i * 100) / CAL_FRAMES;
      int barW = (128 * pct) / 100;
      u8g2.clearBuffer();
      u8g2.setFont(u8g2_font_6x10_tr);
      drawTextCenter("Light Calib", 10);
      u8g2.drawFrame(0, 18, 128, 10);
      if (barW > 0) u8g2.drawBox(0, 18, barW, 10);
      char pctBuf[8];
      snprintf(pctBuf, sizeof(pctBuf), "%d%%", pct);
      drawTextCenter(pctBuf, 31);
      u8g2.sendBuffer();
    }
    delay(CAL_DELAY_MS);
    yield();
  }

  if (prevJpegBuf) { free(prevJpegBuf); prevJpegBuf = NULL; }
  prevJpegLen = 0;

  showStatusMsg("Guard Ready", "Watching...");
  delay(400);
  Serial.println("Guard: Isik kalibrasyonu tamamlandi.");
}

void guardCleanup() {
  if (prevJpegBuf) { free(prevJpegBuf); prevJpegBuf = NULL; }
  prevJpegLen = 0;
}

void runSecurityMode() {
  static uint32_t lastFrameTime = 0;
  static bool     guardReady    = false;
  static int      warmupFrames  = 0;
  uint32_t now = millis();

  if (now - lastFrameTime < GUARD_FRAME_DELAY) return;
  lastFrameTime = now;

  if (!guardReady) {
    guardInit();
    guardReady   = true;
    warmupFrames = 0;
    return;
  }

  camera_fb_t* fb = esp_camera_fb_get();
  if (!fb) { Serial.println("Guard: Frame alinamadi!"); return; }

  if (warmupFrames < 5) {
    warmupFrames++;
    if (warmupFrames == 5) {
      if (prevJpegBuf) free(prevJpegBuf);
      prevJpegBuf = (uint8_t*)(psramAvail ? ps_malloc(fb->len) : malloc(fb->len));
      if (prevJpegBuf) { memcpy(prevJpegBuf, fb->buf, fb->len); prevJpegLen = fb->len; }
    }
    esp_camera_fb_return(fb);
    return;
  }

  if (!prevJpegBuf || prevJpegLen == 0) {
    prevJpegBuf = (uint8_t*)(psramAvail ? ps_malloc(fb->len) : malloc(fb->len));
    if (prevJpegBuf) { memcpy(prevJpegBuf, fb->buf, fb->len); prevJpegLen = fb->len; }
    esp_camera_fb_return(fb);
    return;
  }

  size_t cmpLen = min(prevJpegLen, fb->len);
  int diffCount = 0, totalCompared = 0;
  for (size_t i = 0; i < cmpLen; i += 4) {
    if (abs((int)fb->buf[i] - (int)prevJpegBuf[i]) > 25) diffCount++;
    totalCompared++;
  }
  int sizeDiff = abs((int)fb->len - (int)prevJpegLen);
  float sizeChangePct = (prevJpegLen > 0) ? (sizeDiff * 100.0f / prevJpegLen) : 0;
  float byteChangePct = (totalCompared > 0) ? (diffCount * 100.0f / totalCompared) : 0;

  static int frameNum = 0;
  frameNum++;
  if (frameNum % 3 == 0)
    Serial.printf("Guard #%d: Byte=%.1f%% Size=%.1f%%\n", frameNum, byteChangePct, sizeChangePct);

  if (fb->len != prevJpegLen) {
    free(prevJpegBuf);
    prevJpegBuf = (uint8_t*)(psramAvail ? ps_malloc(fb->len) : malloc(fb->len));
  }
  if (prevJpegBuf) { memcpy(prevJpegBuf, fb->buf, fb->len); prevJpegLen = fb->len; }
  esp_camera_fb_return(fb);

  bool frameHasMotion = (byteChangePct > 40.0f) || (sizeChangePct > 50.0f);
  static int consecutiveMotion = 0;
  if (frameHasMotion) consecutiveMotion++;
  else                consecutiveMotion = 0;
  if (consecutiveMotion < 3) return;
  consecutiveMotion = 0;

  // ===== HAREKET ALGILANDI =====
  Serial.printf("HAREKET! Byte=%.1f%% Size=%.1f%%\n", byteChangePct, sizeChangePct);

  // 3 tap ile iptal edilebilir bekleme yardimcisi
  // true donerse iptal, false donerse normal tamamlandi
  auto tapDelay = [](uint32_t ms) -> bool {
    uint32_t t = millis();
    while (millis() - t < ms) {
      if (checkTap() == 2) return true;
      delay(10);
    }
    return false;
  };

  showStatusMsg("!! MOTION !!", "2x:Cancel");
  if (tapDelay(400)) {
    // Iptal: guard modundan ana menuye don
    guardReady = false; warmupFrames = 0;
    currentAppMode = MAIN_MENU; drawMainMenu();
    return;
  }

  guardCleanup();
  u8g2.setPowerSave(1);

  sensor_t* s = esp_camera_sensor_get();
  if (s) s->set_framesize(s, FRAMESIZE_VGA);
  if (tapDelay(400)) {
    u8g2.setPowerSave(0);
    if (s) s->set_framesize(s, FRAMESIZE_QQVGA);
    guardReady = false; warmupFrames = 0;
    currentAppMode = MAIN_MENU; drawMainMenu();
    return;
  }

  // Ilk kareyi at (sensor stabilizasyonu)
  camera_fb_t* warmFb = esp_camera_fb_get();
  if (warmFb) { esp_camera_fb_return(warmFb); delay(80); }

  uint8_t** bufs  = (uint8_t**)malloc(maxFrames * sizeof(uint8_t*));
  size_t*   sizes = (size_t*)  malloc(maxFrames * sizeof(size_t));
  int   count       = 0;
  bool  capCancelled = false;

  if (bufs && sizes) {
    for (int i = 0; i < maxFrames; i++) {
      if (checkTap() == 2) { capCancelled = true; break; }
      fb = esp_camera_fb_get();
      if (fb) {
        uint8_t* mem = psramAvail ? (uint8_t*)ps_malloc(fb->len) : (uint8_t*)malloc(fb->len);
        if (mem) { memcpy(mem, fb->buf, fb->len); bufs[count] = mem; sizes[count] = fb->len; count++; }
        esp_camera_fb_return(fb);
      }
      yield(); delay(50);
    }
  }

  if (capCancelled || !bufs || !sizes) {
    // Iptal veya bellek hatasi
    u8g2.setPowerSave(0);
    if (bufs) { for (int i = 0; i < count; i++) if (bufs[i]) free(bufs[i]); free(bufs); }
    if (sizes) free(sizes);
    if (s) s->set_framesize(s, FRAMESIZE_QQVGA);
    guardReady = false; warmupFrames = 0;
    currentAppMode = MAIN_MENU; drawMainMenu();
    return;
  }

  u8g2.setPowerSave(0);
  showStatusMsg("Uploading...", "Please wait...");
  bool uploaded = uploadStreamToVPS(bufs, sizes, count, 640, 480);
  for (int i = 0; i < count; i++) if (bufs[i]) free(bufs[i]);
  free(bufs); free(sizes);

  if (uploaded) showStatusMsg("Alert Sent!", g_guardLoop ? "Watching..." : "Done.");
  else          showStatusMsg("Upload FAIL", "WiFi/VPS err");

  delay(2000);

  if (s) s->set_framesize(s, FRAMESIZE_QQVGA);

  if (g_guardLoop) {
    guardReady   = false;
    warmupFrames = 0;
    drawSecurityScreen();
    Serial.println("Guard: Izlemeye devam ediliyor...");
  } else {
    guardReady     = false;
    warmupFrames   = 0;
    currentAppMode = MAIN_MENU;
    drawMainMenu();
    Serial.println("Guard: One-shot - ana menuye donuldu.");
  }
}

