void drawTimelapseScreen() {
  uint32_t now  = millis();
  uint32_t rem  = (g_tlNextShot > now) ? (g_tlNextShot - now) / 1000 : 0;
  int      mins = rem / 60;
  int      secs = rem % 60;

  u8g2.clearBuffer();
  drawHeader();
  u8g2.setFont(u8g2_font_6x10_tr);

  char l1[24];
  snprintf(l1, sizeof(l1), "TL #%d", g_tlTotalFrames + g_tlCount);
  drawTextCenter(l1, 11);

  char l2[24];
  if (mins > 0) snprintf(l2, sizeof(l2), "Sonraki:%d:%02d", mins, secs);
  else          snprintf(l2, sizeof(l2), "Sonraki: %ds", (int)rem);
  drawTextCenter(l2, 21);

  u8g2.setFont(u8g2_font_4x6_tr);
  u8g2.drawStr(1, 31, "3x:Bitir+Gonder");
  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.sendBuffer();
}

