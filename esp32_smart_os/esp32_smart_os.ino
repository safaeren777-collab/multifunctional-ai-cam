    delay(10);
  }
  Serial.println("Mikrofon hazir.");
}

// =========================================================
//  TAP ALGILAMA  (v3.7 — iki kritik hata duzeltildi)
//
//  Duzeltme 1 — prevPeak=0 hatasi:
//    Eskiden cooldown bittikten sonra prevPeak=0 yapiliyordu.
//    Ama cooldown blogu return 0 ile cikiyor yani peak hesaplanmadan once.
//    Sonraki cagride prevPeak=0 olunca ambient ses bile (1200+) tap gibi gorundugu oluyordu.
//    Duzeltme: peak'i her zaman once hesapla, cooldown cikisinda prevPeak=peak yap.
//
//  Duzeltme 2 — rezonans sorunu:
//    TAP_DEBOUNCE_MS=120ms: tek taptan sonra 130ms'de hala rezonans olabilir.
//    Bu rezonans delta>1100 yaparsa 2. tap sayiliyordu (2 fiziksel tap → 3 sayiliyor).
//    Duzeltme: TAP_DEBOUNCE_MS=200ms.
//
//  Donen deger: 0=yok, 1=tek tap, 2=cift tap, 3=uc tap  (4+ yoksayilir)
// =========================================================
int checkTap() {
  static uint8_t  tapState    = 0;  // 0=idle, 1=sayiyor, 2=cooldown
  static uint32_t lastTapTime = 0;
  static uint8_t  tapCount    = 0;
  static uint32_t cooldownEnd = 0;
  static int16_t  prevPeak    = 0;
  uint32_t now = millis();

  micI2S.readBytes((char*)micBuf, sizeof(micBuf));

  // ── Peak her zaman once hesaplanir ─────────────────────
  // (cooldown cikisinda prevPeak'i dogru baslangic degerine setlemek icin)
  int16_t peak = 0;
  for (int i = 0; i < 160; i++) {
    int16_t s = abs(micBuf[i]);
    if (s > peak) peak = s;
  }

  // ── Cooldown kontrolu ──────────────────────────────────
  if (tapState == 2) {
    if (now >= cooldownEnd) {
      tapState = 0;
      tapCount = 0;
      prevPeak = peak;  // DUZELTME: 0 degil, gercek seviyeye esitle
    }
    return 0;
  }

  // ── Delta hesapla ──────────────────────────────────────
  int16_t delta = peak - prevPeak;
  prevPeak = peak;
  bool tapped = (delta > TAP_DELTA_MIN);

  // ── Bosta: ilk tap bekleniyor ──────────────────────────
  if (tapState == 0) {
    if (tapped) { tapState = 1; tapCount = 1; lastTapTime = now; }
    return 0;
  }

  // ── Sayma: yeni tap var mi? ────────────────────────────
  if (tapped && (now - lastTapTime) > TAP_DEBOUNCE_MS) {
    tapCount++;
    lastTapTime = now;
    return 0;
  }

  // ── Emit: son taptan TAP_EMIT_DELAY gecti mi? ──────────
  if (now - lastTapTime >= TAP_EMIT_DELAY) {
    uint8_t count = tapCount;
    tapState    = 2;
    cooldownEnd = now + TAP_COOLDOWN_MS;
    tapCount    = 0;
    prevPeak    = peak;  // DUZELTME: 0 degil, gercek seviyeye esitle
    if (count >= 1 && count <= 3) return count;  // 1, 2 veya 3 tap: gecerli
    return 0;  // 4+ tap: yoksay
  }

  return 0;
}

// =========================================================
//  WAV HEADER (44 byte, little-endian)
//  mic_quality_test ile ayni format: 16kHz 16-bit mono PCM
// =========================================================
void buildWavHeader(uint8_t* hdr, uint32_t dataBytes) {
  uint32_t fileSize  = dataBytes + 36;
  uint32_t sr        = 16000;
  uint32_t byteRate  = 16000 * 2;
  uint16_t blockAl   = 2;
  uint16_t bitsPS    = 16;
  uint16_t numCh     = 1;
  uint16_t audioFmt  = 1;   // PCM
  uint32_t fmtChunk  = 16;
  memcpy(hdr +  0, "RIFF",    4);  memcpy(hdr +  4, &fileSize, 4);
  memcpy(hdr +  8, "WAVE",    4);  memcpy(hdr + 12, "fmt ",    4);
  memcpy(hdr + 16, &fmtChunk, 4);  memcpy(hdr + 20, &audioFmt, 2);
  memcpy(hdr + 22, &numCh,    2);  memcpy(hdr + 24, &sr,       4);
  memcpy(hdr + 28, &byteRate, 4);  memcpy(hdr + 32, &blockAl,  2);
  memcpy(hdr + 34, &bitsPS,   2);  memcpy(hdr + 36, "data",    4);
  memcpy(hdr + 40, &dataBytes,4);
}

// =========================================================
//  SES KOMUTU VPS'E GONDER → Komut adini don
//  VPS /voice_command → Gemini → "guard"/"ai"/"photo"/...
// =========================================================
String sendVoiceToVPS(uint8_t* wavData, size_t wavSize) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("sendVoiceToVPS: WiFi yok");
    return "";
  }

  WiFiClient client;
  bool connected = false;
  for (int attempt = 1; attempt <= 3 && !connected; attempt++) {
    connected = client.connect(vps_host.c_str(), vps_port);
    if (!connected) { Serial.printf("  Baglanti %d/3 basarisiz\n", attempt); delay(600); }
  }
  if (!connected) { Serial.println("sendVoiceToVPS: VPS baglantisi kurulamadi!"); return ""; }

  const String boundary = "VOICECMD123";
  String head =
    "--" + boundary + "\r\n"
    "Content-Disposition: form-data; name=\"audio\"; filename=\"voice_cmd.wav\"\r\n"
    "Content-Type: audio/wav\r\n\r\n";
  String tail = "\r\n--" + boundary + "--\r\n";
  long totalLen = head.length() + (long)wavSize + tail.length();

  client.println("POST /voice_command HTTP/1.1");
  client.println("Host: " + vps_host);
  client.println("Content-Type: multipart/form-data; boundary=" + boundary);
  client.print("Content-Length: "); client.println(totalLen);
  client.println("Connection: close");
  client.println();
  client.print(head);

  size_t sent = 0;
  while (sent < wavSize) {
    size_t chunk   = min((size_t)4096, wavSize - sent);
    size_t written = client.write(wavData + sent, chunk);
    if (written > 0) sent += written; else delay(10);
    yield();
  }
  client.print(tail);

  String responseBody = "";
  bool   isBody       = false;
  long   start        = millis();
  while ((client.connected() || client.available()) && millis() - start < 30000) {
    if (client.available()) {
      String line = client.readStringUntil('\n');
      line.trim();
      if (isBody) responseBody += line;
      else if (line == "") isBody = true;
    }
    yield();
  }
  client.stop();

  Serial.printf("VPS yaniti: %s\n", responseBody.c_str());
  DynamicJsonDocument doc(256);
  if (!deserializeJson(doc, responseBody) && doc.containsKey("command")) {
    return doc["command"].as<String>();
  }
  return "";
}

