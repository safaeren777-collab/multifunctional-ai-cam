bool sendPhotoToVPS(uint8_t* buf, size_t len) {
  if (WiFi.status() != WL_CONNECTED) return false;
  WiFiClient client;
  if (!client.connect(vps_host.c_str(), vps_port)) return false;

  const String boundary = "CLASSBND";
  const String head = "--" + boundary +
    "\r\nContent-Disposition: form-data; name=\"image\"; filename=\"photo.jpg\"\r\n"
    "Content-Type: image/jpeg\r\n\r\n";
  const String tail = "\r\n--" + boundary + "--\r\n";
  long totalLen = head.length() + len + tail.length();

  client.println("POST /send_photo HTTP/1.1");
  client.println("Host: " + vps_host);
  client.println("Content-Type: multipart/form-data; boundary=" + boundary);
  client.print("Content-Length: "); client.println(totalLen);
  client.println("Connection: close");
  client.println();
  client.print(head);

  size_t sent = 0;
  while (sent < len) {
    size_t chunk   = min((size_t)2048, len - sent);
    size_t written = client.write(buf + sent, chunk);
    if (written > 0) sent += written; else delay(10);
    yield();
  }
  client.print(tail);

  bool ok = false;
  long start = millis();
  while ((client.connected() || client.available()) && millis() - start < 15000) {
    if (client.available()) {
      String line = client.readStringUntil('\n');
      if (line.indexOf("200 OK") >= 0) ok = true;
    }
    yield();
  }
  client.stop();
  return ok;
}

void takeClassicPhoto() {
  // Her zaman geri sayim (ayardan bagimsiz klasik modda hep acik)
  if (!runCountdown(g_photoTimer ? 3 : 0, "PHOTO")) {
    drawClassicViewfinder();
    return;
  }
  showStatusMsg("Capturing...", "");

  sensor_t* s = esp_camera_sensor_get();
  if (s) {
    s->set_framesize(s, FRAMESIZE_SXGA);
    delay(300);  // ilk oturma süresi
  }

  // Isınma kareleri (5x): ani akim spike'ini engeller.
  // Kamera SXGA'ya gecince ilk kareler bozuk + güç tüketimi aniden yükselir.
  // Her kareyi okuyup atarak sensör güç tüketimini YAVAŞÇA rampaya alıyoruz.
  // Guard mod gibi → sıfırdan başlayan soğuk çekim yerine ısınmış kamera.
  for (int i = 0; i < 5; i++) {
    camera_fb_t* flush = esp_camera_fb_get();
    if (flush) esp_camera_fb_return(flush);
    delay(50);
  }

  camera_fb_t* fb = esp_camera_fb_get();
  if (!fb) {
    // Basarisizsa framesize'i geri al, ekrana yaz
    if (s) s->set_framesize(s, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
    showStatusMsg("Capture Fail", "");
    delay(1500);
    drawClassicViewfinder();
    return;
  }

  showStatusMsg("Sending...", "Telegram");
  classicLastOk = sendPhotoToVPS(fb->buf, fb->len);

  // ÖNEMLİ: set_framesize ÖNCE, fb_return SONRA çağrılmalı.
  // fb tutuluyken kamera DMA'sı duruyor → set_framesize güvenli.
  // fb_return sonra çağrılırsa DMA hemen VGA modunda başlar (çakışma yok).
  // Ters sırada: fb_return → DMA SXGA'da başlar → set_framesize çakışır → RESET.
  if (s) {
    s->set_framesize(s, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
    delay(100);  // sensör yeni boyuta geçsin
  }
  esp_camera_fb_return(fb);

  classicState = CS_DONE;
  drawClassicDone();
}

// =========================================================
//  VPS'E STREAM YUKLE
// =========================================================
bool uploadStreamToVPS(uint8_t** buffers, size_t* sizes, int count, int imgW, int imgH, int fps) {
  if (count == 0) return false;

  if (WiFi.status() != WL_CONNECTED) {
    showStatusMsg("WiFi yok", "Baglaniliyor...");
    WiFi.reconnect();
    uint32_t t = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - t < 10000) { delay(200); yield(); }
    if (WiFi.status() != WL_CONNECTED) return false;
  }

  WiFiClient client;
  bool connected = false;
  for (int attempt = 1; attempt <= 3 && !connected; attempt++) {
    connected = client.connect(vps_host.c_str(), vps_port);
    if (!connected) { Serial.printf("VPS baglanti %d/3 basarisiz\n", attempt); delay(500); }
  }
  if (!connected) return false;

  const String boundary = "ESP32STREAMBND";
  const String head = "--" + boundary +
    "\r\nContent-Disposition: form-data; name=\"files\"; filename=\"frame.jpg\"\r\n"
    "Content-Type: image/jpeg\r\n\r\n";
  const String tail     = "\r\n";
  const String endBound = "--" + boundary + "--\r\n";

  long totalLen = 0;
  for (int i = 0; i < count; i++) totalLen += head.length() + sizes[i] + tail.length();
  totalLen += endBound.length();

  client.println("POST " + stream_url + " HTTP/1.1");
  client.println("Host: " + vps_host);
  client.println("Content-Type: multipart/form-data; boundary=" + boundary);
  client.print("Content-Length: ");  client.println(totalLen);
  client.print("X-Frame-Width: ");   client.println(imgW);
  client.print("X-Frame-Height: ");  client.println(imgH);
  client.print("X-Frame-FPS: ");     client.println(fps);
  client.println("Connection: close");
  client.println();

  bool sendOk = true;
  for (int i = 0; i < count && sendOk; i++) {
    client.print(head);
    size_t sent = 0;
    while (sent < sizes[i]) {
      size_t chunk   = min((size_t)2048, sizes[i] - sent);
      size_t written = client.write(buffers[i] + sent, chunk);
      if (written > 0) sent += written; else delay(10);
      drawUploadAnim();  // guard upload animasyonu
      yield();
    }
    client.print(tail);
  }

  if (!sendOk) { client.stop(); return false; }
  client.print(endBound);

  bool success = false;
  long start   = millis();
  while ((client.connected() || client.available()) && millis() - start < UPLOAD_TIMEOUT_MS) {
    if (client.available()) {
      String line = client.readStringUntil('\n');
      Serial.println(line);
      if (line.indexOf("200 OK") >= 0) success = true;
    }
    yield();
  }
  client.stop();
  Serial.printf("Upload %s: %d kare\n", success ? "OK" : "hata", count);
  return success;
}

// =========================================================
//  AI MODU
// =========================================================
void runAiMode() {
  showStatusMsg("AI ASSIST", "Capturing...");

  sensor_t* s = esp_camera_sensor_get();
  if (!s) {
    showStatusMsg("CAM ERROR!", "");
    delay(2000);
    currentAppMode = MAIN_MENU;
    drawMainMenu();
    return;
  }

  s->set_framesize(s, FRAMESIZE_UXGA);
  delay(300);  // ilk oturma süresi

  // Isınma kareleri (5x): ani akim spike'ini engeller + eski DMA karelerini temizler.
  // CAMERA_GRAB_WHEN_EMPTY modunda önceki çekimden kalan kare gelebilir;
  // flush ile hem eski veri hem de güç rampası sorunu çözülür.
  for (int i = 0; i < 5; i++) {
    camera_fb_t* flush = esp_camera_fb_get();
    if (flush) esp_camera_fb_return(flush);
    delay(60);
  }

  // Deklansor efekti (ekran kararma = foto cekiliyor)
  u8g2.clearBuffer();
  u8g2.drawBox(0, 0, 128, 32);
  u8g2.sendBuffer();
  delay(150);

  camera_fb_t* fb = esp_camera_fb_get();
  if (!fb) {
    if (s) s->set_framesize(s, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
    showStatusMsg("CAPTURE FAIL", "");
    delay(2000);
    currentAppMode = MAIN_MENU;
    drawMainMenu();
    return;
  }

  showStatusMsg("Analyzing...", "Please wait");

  WiFiClient client;
  const String boundary = "AIBND";
  const String head = "--" + boundary +
    "\r\nContent-Disposition: form-data; name=\"image\"; filename=\"img.jpg\"\r\n"
    "Content-Type: image/jpeg\r\n\r\n";
  const String tail = "\r\n--" + boundary + "--\r\n";
  long totalLen = (long)head.length() + fb->len + tail.length();

  if (client.connect(vps_host.c_str(), vps_port)) {
    client.println("POST " + ai_url + " HTTP/1.1");
    client.println("Host: " + vps_host);
    client.println("Content-Type: multipart/form-data; boundary=" + boundary);
    client.print("Content-Length: "); client.println(totalLen);
    client.println("Connection: close");
    client.println();

    client.print(head);
    size_t sent = 0;
    while (sent < fb->len) {
      size_t chunk   = min((size_t)2048, fb->len - sent);
      size_t written = client.write(fb->buf + sent, chunk);
      if (written > 0) sent += written; else delay(10);
      yield();
    }
    client.print(tail);

    long     startTime   = millis();
    int      animFrame   = 0;
    uint32_t lastAnim    = 0;
    String   responseBody = "";
    bool     isBody      = false;

    while ((client.connected() || client.available()) && millis() - startTime < AI_TIMEOUT_MS) {
      while (client.available()) {
        String line = client.readStringUntil('\n');
        line.trim();
        if (isBody)          responseBody += line;
        else if (line == "") isBody = true;
      }
      
      uint32_t now = millis();
      if (now - lastAnim >= AI_ANIM_DELAY) {
        u8g2.clearBuffer();
        drawHeader();
        u8g2.drawBitmap(48, 0, 4, 32, aiFrames[animFrame]);
        u8g2.sendBuffer();
        animFrame = (animFrame + 1) % AI_ANIM_COUNT;
        lastAnim = now;
      }
      yield();
    }
    client.stop();

    DynamicJsonDocument doc(1024);
    DeserializationError err = deserializeJson(doc, responseBody);
    if (!err && doc.containsKey("result")) aiResult = doc["result"].as<String>();
    else { aiResult = "Parse Error"; Serial.println("JSON hatasi: " + responseBody); }
  } else {
    aiResult = "Network Error";
  }

  // ÖNEMLİ: set_framesize ÖNCE (fb tutuluyken DMA duruyor), fb_return SONRA çağrılmalı.
  // Ters sırada: fb_return → DMA UXGA'da başlar → set_framesize çakışır → RESET.
  // Ayrıca: UXGA'da bırakılırsa bir sonraki AI çekiminde ghost frame riski vardır.
  if (s) {
    s->set_framesize(s, psramAvail ? FRAMESIZE_VGA : FRAMESIZE_QVGA);
    delay(100);
  }
  esp_camera_fb_return(fb);

  currentAppMode = RESULT_VIEW;
  displayAiResult(aiResult);
}

