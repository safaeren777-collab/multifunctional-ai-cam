// =========================================================
//  IT SUPPORT MOD
//  USB HID klavye aracılığıyla PC'yi otomatik teshis eder.
//
//  Akış:
//    1. initMode(IT_MODE) → VPS'e kayıt → session ID al
//    2. Telegram'dan /e "sorun" gelince VPS haberdar eder
//    3. loop() → runItMode() her 2sn VPS'i poll eder
//    4. Komut gelince WIN+R → bootstrap komutu yaz
//    5. PC script'i VPS'ten indirir ve çalıştırır
//    6. PC veriyi doğrudan VPS'e POST atar
//    7. Gemini analiz → plan Telegram'a gelir
//    8. Teknisyen ✅ → fix aynı şekilde uygulanır
//    9. 3x tap → IT moddan çık
// =========================================================

void drawItScreen() {
  u8g2.clearBuffer();
  drawHeader();
  u8g2.setFont(u8g2_font_6x10_tr);
  drawTextCenter("IT SUPPORT", 12);

  if (g_itRegistered) {
    char buf[24];
    snprintf(buf, sizeof(buf), "#%s OK", g_itSessionId);
    drawTextCenter(buf, 22);
  } else {
    char buf[24];
    snprintf(buf, sizeof(buf), "VPS... %d", g_itRegisterRetryCount);
    drawTextCenter(buf, 22);
  }

  u8g2.setFont(u8g2_font_4x6_tr);
  u8g2.drawStr(1, 31, "3x:Cik");
  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.sendBuffer();
}

// =========================================================
//  VPS'e kayit — non-blocking, kisa timeout, retry destekli
//  Maksimum ~3sn blocking (connect 1.5sn + read 1.5sn)
//  Bu sure tap kacirsa bile, kullanici 3x tap'i tekrar yapabilir
// =========================================================
bool itRegisterVPS() {
  // Yeni session ID
  // Lowercase hex: VPS bootstrap'inda lowercase URL kullaniliyor (TR Q'da
  // uppercase typing daha cok ALT+code gerektirir, lowercase daha hizli)
  snprintf(g_itSessionId, sizeof(g_itSessionId), "%08x", (unsigned)esp_random());

  WiFiClient client;
  client.setTimeout(2);   // Genel timeout 2sn

  // Kisa connect timeout: 1500ms
  uint32_t cs = millis();
  if (!client.connect(vps_host.c_str(), vps_port, 1500)) {
    Serial.printf("IT: kayit connect hatasi (%ums)\n", (unsigned)(millis() - cs));
    return false;
  }

  char body[48];
  snprintf(body, sizeof(body), "{\"session_id\":\"%s\"}", g_itSessionId);
  int blen = strlen(body);

  client.printf(
    "POST /it_register HTTP/1.1\r\n"
    "Host: %s\r\n"
    "Content-Type: application/json\r\n"
    "Content-Length: %d\r\n"
    "Connection: close\r\n\r\n"
    "%s",
    vps_host.c_str(), blen, body
  );

  // Read deadline: 1500ms
  uint32_t deadline = millis() + 1500;
  bool ok = false;
  bool sawStatus = false;
  while (millis() < deadline) {
    if (client.available()) {
      String line = client.readStringUntil('\n');
      if (!sawStatus) {
        sawStatus = true;
        if (line.indexOf("200") >= 0) ok = true;
      }
      // Geri kalani goz ardi — body parse etmeye gerek yok
    } else if (!client.connected() && client.available() == 0) {
      break;
    }
    yield();
  }
  client.stop();

  if (ok) {
    g_itRegistered         = true;
    g_itRegisterRetryCount = 0;
    Serial.printf("IT: VPS kaydedildi #%s\n", g_itSessionId);
  } else {
    Serial.printf("IT: kayit yaniti hatali (sawStatus=%d)\n", (int)sawStatus);
  }
  return ok;
}

// =========================================================
//  Tek poll — komut gelirse type=... doner, yoksa "" doner
//  Maksimum ~3sn blocking
// =========================================================
String itPollVPS() {
  WiFiClient client;
  client.setTimeout(2);
  if (!client.connect(vps_host.c_str(), vps_port, 1500)) {
    return "";
  }

  char path[40];
  snprintf(path, sizeof(path), "/it_poll/%s", g_itSessionId);
  client.printf(
    "GET %s HTTP/1.1\r\nHost: %s\r\nConnection: close\r\n\r\n",
    path, vps_host.c_str()
  );

  String resp = "";
  bool   inBody = false;
  uint32_t deadline = millis() + 1500;
  while (millis() < deadline) {
    if (client.available()) {
      String line = client.readStringUntil('\n');
      if (!inBody) {
        // HTTP header sonu: '\r' satiri (CRLF -> '\n' okundu, '\r' kaldi)
        if (line.length() == 0 || line == "\r") inBody = true;
      } else {
        resp += line;
      }
    } else if (!client.connected() && client.available() == 0) {
      break;
    }
    yield();
  }
  client.stop();
  resp.trim();
  if (resp.length() == 0) return "";

  // JSON parse — bootstrap field'i yaklasik 254 char olabilir, buffer arttir
  StaticJsonDocument<1024> doc;
  if (deserializeJson(doc, resp) != DeserializationError::Ok) {
    Serial.printf("IT: poll JSON parse hata: %s\n", resp.substring(0, 80).c_str());
    return "";
  }
  if (doc["cmd"].isNull()) return "";

  const char* cmdType   = doc["cmd"]["type"] | "collect";
  const char* bootstrap = doc["bootstrap"]    | "";

  // Bootstrap'i global'e koy (runItMode typing pending state'inde kullanacak)
  g_itPendingBootstrap = String(bootstrap);

  Serial.printf("IT: Komut alindi: type=%s, bootstrap_len=%d\n",
                cmdType, g_itPendingBootstrap.length());
  return String(cmdType);
}

// =========================================================
//  loop() icinden cagrilir — state machine
//  HER state minimum blocking yapar; arada checkTap() calisabilir
// =========================================================
void runItMode() {
  uint32_t now = millis();

  // ── State 1: Kayit gerekli ─────────────────────────────
  if (g_itState == IT_S_NEED_REGISTER) {
    // 4 saniyede bir dene; tap'a yer birak
    if (now - g_itLastRegisterAttemptMs < 4000 && g_itLastRegisterAttemptMs != 0) {
      return;
    }
    g_itLastRegisterAttemptMs = now;

    if (WiFi.status() != WL_CONNECTED) {
      // WiFi yok - bekle, retry artir gostergesi olsun
      return;
    }

    g_itRegisterRetryCount++;
    drawItScreen();      // "VPS... N" goster

    if (itRegisterVPS()) {
      g_itState = IT_S_IDLE;
      drawItScreen();
    }
    // Basarisiz olsa bile state degismez, 4sn sonra tekrar denenecek
    return;
  }

  // ── State 2: Idle - periodic poll ──────────────────────
  if (g_itState == IT_S_IDLE) {
    if (now - g_itLastPollMs < 2000) return;
    g_itLastPollMs = now;

    if (WiFi.status() != WL_CONNECTED) return;

    String cmdType = itPollVPS();
    if (cmdType.length() > 0) {
      g_itPendingCmdType = cmdType;
      g_itState          = IT_S_TYPING_PENDING;
    }
    return;
  }

  // ── State 3: Typing pending - PC'ye yaz ────────────────
  if (g_itState == IT_S_TYPING_PENDING) {
    bool isTest = (g_itPendingCmdType == "test_keyboard");

    if (g_itPendingCmdType == "collect") {
      showStatusMsg("IT: Teshis", "Komut yaziliyor");
    } else if (g_itPendingCmdType == "fix") {
      showStatusMsg("IT: Fix", "Komut yaziliyor");
    } else if (isTest) {
      showStatusMsg("KLAVYE TEST", "Notepad acılıyor");
    } else {
      showStatusMsg("IT: Komut", g_itPendingCmdType.c_str());
    }
    delay(300);

    if (isTest) {
      itTypeKeyboardTest();
    } else {
      // VPS'ten gelen Base64 encoded bootstrap'i kullan
      if (g_itPendingBootstrap.length() == 0) {
        Serial.println("IT: HATA - bootstrap bos! VPS cevap formatini kontrol et.");
        showStatusMsg("IT HATA", "Bootstrap bos");
        delay(1500);
      } else {
        itTypeBootstrapOnPc(g_itPendingBootstrap);
      }
    }

    // Typing bitti - idle'a don. delay(3000) YOK!
    g_itPendingCmdType   = "";
    g_itPendingBootstrap = "";
    g_itState            = IT_S_IDLE;
    g_itLastPollMs       = millis();
    drawItScreen();
    return;
  }
}

// =========================================================
//  Bootstrap akisi (v3.28): Notepad → Clipboard → PowerShell
//
//  PowerShell konsolda ALT+code calismadigi icin once Notepad'de
//  komutu yaziyoruz (orada ALT+code calisir), Ctrl+A+C ile clipboard'a
//  aliyoruz, Notepad'i kapatip PowerShell'i aciyoruz, Ctrl+V ile paste.
//
//  Ctrl+A, Ctrl+C, Ctrl+V universal kisayollar (layout-bagimsiz).
// =========================================================
void itTypeBootstrapOnPc(const String& bootstrapCmd) {
  // ──── ADIM 1: ESC + Notepad ac ──────────────────────────
  g_HIDKbd.press(KEY_ESC);
  g_HIDKbd.releaseAll();
  delay(150);

  g_HIDKbd.press(KEY_LEFT_GUI);
  g_HIDKbd.press('r');
  delay(100);
  g_HIDKbd.releaseAll();
  delay(900);

  itTypeStringHID("notepad");
  delay(120);
  g_HIDKbd.write(KEY_RETURN);
  delay(2500);   // Notepad acilana kadar

  // ──── ADIM 2: Komutu Notepad'e yaz ──────────────────────
  // ALT+code burada calisir, ozel chars dogru basilir
  itTypeStringHID(bootstrapCmd);
  delay(300);

  // ──── ADIM 3: Ctrl+A select all → Ctrl+C copy ──────────
  g_HIDKbd.press(KEY_LEFT_CTRL);
  g_HIDKbd.press('a');
  delay(60);
  g_HIDKbd.releaseAll();
  delay(150);

  g_HIDKbd.press(KEY_LEFT_CTRL);
  g_HIDKbd.press('c');
  delay(60);
  g_HIDKbd.releaseAll();
  delay(300);

  // ──── ADIM 4: Notepad'i kapat (Alt+F4 → Tab → Enter) ───
  // Save dialog acilirsa: Tab moves Save → Don't Save, Enter aktive eder
  g_HIDKbd.press(KEY_LEFT_ALT);
  g_HIDKbd.press(KEY_F4);
  delay(60);
  g_HIDKbd.releaseAll();
  delay(800);   // Save dialog acilsin (varsa)

  g_HIDKbd.press(KEY_TAB);
  delay(60);
  g_HIDKbd.releaseAll();
  delay(120);
  g_HIDKbd.write(KEY_RETURN);
  delay(700);

  // ──── ADIM 5: Win+R → powershell → Enter ────────────────
  g_HIDKbd.press(KEY_LEFT_GUI);
  g_HIDKbd.press('r');
  delay(100);
  g_HIDKbd.releaseAll();
  delay(900);

  itTypeStringHID("powershell");
  delay(120);
  g_HIDKbd.write(KEY_RETURN);
  delay(2500);   // PS konsolu acilsin

  // ──── ADIM 6: Ctrl+V paste, Enter ───────────────────────
  g_HIDKbd.press(KEY_LEFT_CTRL);
  g_HIDKbd.press('v');
  delay(60);
  g_HIDKbd.releaseAll();
  delay(400);

  g_HIDKbd.write(KEY_RETURN);
  delay(50);

  Serial.printf("IT: Notepad+Clipboard akisi tamamlandi (%d karakter)\n",
                bootstrapCmd.length());
}

// =========================================================
//  HID TYPING — HIBRIT (v3.26, layout-bagimsiz)
//
//  Strateji:
//    - Lowercase a-z (i HARIC): direkt scancode (TR Q'da dogru)
//    - Digit 0-9: direkt scancode
//    - Space: direkt scancode
//    - i, I, uppercase A-Z, ozel karakterler (`-` `:` `/` `(` `)` `'` `.` vs.):
//      ALT+0XXX numpad code (Windows ANSI codepage, layout-bagimsiz)
//
//  Plain command (~80 char) ~7 saniyede yazilir. Tum karakterler dogru basilir.
// =========================================================

// 0..9 icin numpad scancode'lari (USBHIDKeyboard library tanimi)
static const uint8_t IT_KP_DIGITS[10] = {
  0xEA,  // 0 = KEY_KP_0
  0xE1, 0xE2, 0xE3, 0xE4, 0xE5, 0xE6, 0xE7, 0xE8, 0xE9,
};

// ALT+0XXX yontemi: layout-bagimsiz karakter basar
void itTypeAltCode(int ascii) {
  char digits[5];
  snprintf(digits, sizeof(digits), "%04d", ascii);

  g_HIDKbd.releaseAll();
  delay(20);

  g_HIDKbd.press(KEY_LEFT_ALT);
  delay(60);

  for (int i = 0; i < 4; i++) {
    int     d  = digits[i] - '0';
    uint8_t kp = IT_KP_DIGITS[d];
    g_HIDKbd.press(kp);
    delay(28);
    g_HIDKbd.release(kp);
    delay(28);
  }

  g_HIDKbd.release(KEY_LEFT_ALT);
  delay(55);
}

void itTypeStringHID(const String& str) {
  for (int i = 0; i < (int)str.length(); i++) {
    char c = str[i];

    // KRITIK: Her karakter oncesi state cleanup.
    // Yoksa ardisik ALT+code'larda modifier carryover race condition →
    // bazi karakterler (ozellikle uppercase chain icindeki) drop oluyor.
    g_HIDKbd.releaseAll();
    delay(12);

    if (c == '\n' || c == '\r') {
      g_HIDKbd.write(KEY_RETURN);
      delay(25);
      continue;
    }

    bool direct_safe = ((c >= 'a' && c <= 'z') && c != 'i') ||
                       (c >= '0' && c <= '9') ||
                       (c == ' ');

    if (direct_safe) {
      g_HIDKbd.print(c);
      delay(15);
    } else if ((unsigned char)c < 128) {
      itTypeAltCode((int)c);
    } else {
      itTypeAltCode((int)(unsigned char)c);
    }
  }
}

