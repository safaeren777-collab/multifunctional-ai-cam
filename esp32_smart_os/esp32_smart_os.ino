// =========================================================
//  UYKU MODU
//  Deep sleep kullanilmiyor: I2S mikrofon deep sleep'te calismaz.
//  CPU calismeye devam eder, WiFi/kamera kapanir.
//  Cift tap = ESP.restart() ile tam yeniden baslatma.
// =========================================================
void goToSleep() {
  showStatusMsg("Sleeping...", "2x tap: Wake");
  delay(800);
  u8g2.setPowerSave(1);
  hasPrevBlock = false;
  WiFi.disconnect(true);
  WiFi.mode(WIFI_OFF);
  Serial.println("Uyku: Cift tap bekliyor...");

  // Aktivasyon tapinin bitmesini bekle
  for (int i = 0; i < 5; i++) {
    micI2S.readBytes((char*)micBuf, sizeof(micBuf));
    delay(10);
  }

  while (checkTap() != 2) {
    delay(8);
  }

  Serial.println("Uyku: Uyandiriliyor...");
  ESP.restart();
}

// =========================================================
//  KAMERA BASLAT
// =========================================================
bool initCamera() {
  camera_config_t config;
  config.ledc_channel  = LEDC_CHANNEL_0;
  config.ledc_timer    = LEDC_TIMER_0;
  config.pin_d0        = Y2_GPIO_NUM;
  config.pin_d1        = Y3_GPIO_NUM;
  config.pin_d2        = Y4_GPIO_NUM;
  config.pin_d3        = Y5_GPIO_NUM;
  config.pin_d4        = Y6_GPIO_NUM;
  config.pin_d5        = Y7_GPIO_NUM;
  config.pin_d6        = Y8_GPIO_NUM;
  config.pin_d7        = Y9_GPIO_NUM;
  config.pin_xclk      = XCLK_GPIO_NUM;
  config.pin_pclk      = PCLK_GPIO_NUM;
  config.pin_vsync     = VSYNC_GPIO_NUM;
  config.pin_href      = HREF_GPIO_NUM;
  config.pin_sccb_sda  = SIOD_GPIO_NUM;
  config.pin_sccb_scl  = SIOC_GPIO_NUM;
  config.pin_pwdn      = PWDN_GPIO_NUM;
  config.pin_reset     = RESET_GPIO_NUM;
  config.xclk_freq_hz  = 20000000; // 20MHz: OV2640 icin optimal stabilite/fps dengesi
  config.pixel_format  = PIXFORMAT_JPEG;
  config.grab_mode     = CAMERA_GRAB_LATEST;  // Her zaman en yeni kare: ghost frame sorunu olmaz
  config.jpeg_quality  = 15;

  // CRITICAL: Init the camera with the LARGEST framesize any mode will
  // ever request (UXGA = 1600x1200 for AI/Timelapse). The esp32-camera
  // driver allocates DMA + frame buffers at init based on this size and
  // does NOT resize them when set_framesize() is called later. If we
  // initialize at VGA and a mode then jumps to UXGA, the DMA buffer
  // overflows on the next capture and the chip resets.
  // After init, we drop the sensor down to VGA for default operation.
  if (psramAvail) {
    config.frame_size  = FRAMESIZE_UXGA;        // pre-allocate for max
    config.fb_location = CAMERA_FB_IN_PSRAM;
    config.fb_count    = 1;
  } else {
    config.frame_size  = FRAMESIZE_QVGA;        // no PSRAM: stay small
    config.fb_location = CAMERA_FB_IN_DRAM;
    config.fb_count    = 1;
  }

  esp_err_t err = esp_camera_init(&config);
  if (err != ESP_OK) {
    g_camInitError = err;
    Serial.printf("Camera init error: 0x%x\n", err);
    return false;
  }
  g_camInitError = ESP_OK;

  sensor_t* s = esp_camera_sensor_get();
  if (s) {
    // Drop to VGA for default operation (Guard, idle).
    // Modes that need higher resolution will set_framesize() up themselves.
    if (psramAvail) s->set_framesize(s, FRAMESIZE_VGA);

    s->set_brightness(s, 0);
    s->set_contrast(s, 0);
    s->set_saturation(s, 0);
    s->set_whitebal(s, 1);
    s->set_awb_gain(s, 1);
    s->set_exposure_ctrl(s, 1);
    s->set_aec2(s, 1);
    s->set_gain_ctrl(s, 1);
  }

  Serial.println("Camera ready.");
  return true;
}

// =========================================================
//  YARDIMCI
// =========================================================
void reconnectWiFiIfNeeded() {
  static uint32_t lastCheck = 0;
  if (millis() - lastCheck < 10000) return;
  lastCheck = millis();
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("WiFi koptu, yeniden baglaniliyor...");
    WiFi.disconnect();
    WiFi.begin(ssid, password);
  }
}

