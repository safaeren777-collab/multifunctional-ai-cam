void drawMainMenu() {
  if (isScreenSaver) return;
  u8g2.clearBuffer();

  // ── Header: WiFi + tap flash (sağ üst köşe) ─────────────────
  drawHeader();

  // ── Sol ok (önceki mod varsa) ────────────────────────────────
  if (menuCursor > 0) {
    u8g2.setFont(u8g2_font_4x6_tr);
    u8g2.drawStr(2, 18, "<");
    // Önceki modun adından ilk 4 harf — solda küçük ipucu
    char prev[5]; strncpy(prev, menuOptions[menuCursor - 1], 4); prev[4] = '\0';
    u8g2.drawStr(8, 18, prev);
  }

  // ── Sağ ok (sonraki mod varsa) ───────────────────────────────
  if (menuCursor < MENU_ITEMS - 1) {
    u8g2.setFont(u8g2_font_4x6_tr);
