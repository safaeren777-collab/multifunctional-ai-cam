#define BUTTON_PIN          GPIO_NUM_0   // sadece deep sleep wakeup icin
#define SCREEN_SAVER_MS     30000
#define GUARD_FRAME_DELAY   500
#define MAX_FRAMES_PSRAM    15
#define MAX_FRAMES_RAM      6
#define UPLOAD_TIMEOUT_MS   60000
#define AI_TIMEOUT_MS       35000

// ================= TAP ALGILAMA =================
// Delta tabanli: ani yukselmeleri algilar
// Kural: 1 tap = aksiyon, 2 tap = gir/geri, 3 tap = kilit ac/iptal
// Kilit sistemi: 3 tap ile acilir, 40sn hareketsizlikte kapanir
#define TAP_DELTA_MIN    1100   // ani yukselme esigi (kalibrasyona gore: tap ~2490, ambient ~876)
#define TAP_DEBOUNCE_MS   110   // iki tap arasi minimum sure (120→110: hizli cift-tap icin)
#define TAP_EMIT_DELAY    420   // son taptan bu sure sonra karar ver (700→420: cok daha cabuK)
#define TAP_COOLDOWN_MS   350   // event sonrasi bekleme (600→350: hizli ardisik komutlar icin)
#define TAP_LOCK_MS      40000  // bu kadar inaktiflik sonrasi otomatik kilit

// ================= SES KOMUTLARI =================
// Sadece VOICE_MODE icinde aktif — arka planda calismaz, tap sistemi etkilenmez
#define VOICE_CAPTURE_SECS 2     // Komut icin ses kayit suresi (saniye)

// ================= TİMELAPSE =================
// Doldur-bosalt: PSRAM dolar → VPS'e batch gonder → temizle → devam
// Gonderim her zaman capture SONRASINDA yapilir (asla esit zamanda degil)
#define TL_INTERVAL_MS    (2UL * 60UL * 1000UL)  // 2 dakika aralik
#define TL_BATCH_FRAMES   20                       // PSRAM'da max frame (UXGA icin guvenli)
#define TL_FRAMESIZE      FRAMESIZE_UXGA           // maksimum kalite
#define TL_OLED_ON_MS     6000                     // frame sonrasi OLED bu kadar acik kalir
#define VOICE_SAMPLES      (16000 * VOICE_CAPTURE_SECS)   // 32000 sample
#define VOICE_BYTES        (VOICE_SAMPLES * 2)             // 64000 byte (16-bit)
#define VOICE_WAV_TOTAL    (VOICE_BYTES + 44)              // WAV header = 44 byte

// ================= OLED =================
U8G2_SSD1306_128X32_UNIVISION_F_HW_I2C u8g2(U8G2_R0, U8X8_PIN_NONE, 6, 5);

