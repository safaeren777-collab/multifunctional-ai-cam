void buildAiLines(const String& result) {
  g_aiLineCount = 0;
  g_aiPage      = 0;
  u8g2.setFont(u8g2_font_5x7_tr);
  const int maxCPL = 24;
  String rem = result;
  while (rem.length() > 0 && g_aiLineCount < 12) {
    int    len  = min((int)rem.length(), maxCPL);
    String line = rem.substring(0, len);
    if ((int)rem.length() > maxCPL) {
      int lastSp = line.lastIndexOf(' ');
      if (lastSp > 0) line = line.substring(0, lastSp);
    }
    g_aiLines[g_aiLineCount++] = line;
    rem = rem.substring(line.length());
    rem.trim();
  }
  u8g2.setFont(u8g2_font_6x10_tr);
}

void renderAiPage() {
  u8g2.clearBuffer();
  u8g2.setFont(u8g2_font_5x7_tr);
  const int LPP = 4;
  int totalPages = max(1, (g_aiLineCount + LPP - 1) / LPP);
  int startLine  = g_aiPage * LPP;
  for (int i = 0; i < LPP; i++) {
    int idx = startLine + i;
    if (idx >= g_aiLineCount) break;
    int tw = u8g2.getStrWidth(g_aiLines[idx].c_str());
    int x  = max(0, (128 - tw) / 2);
    u8g2.setCursor(x, 7 + i * 8);
    u8g2.print(g_aiLines[idx].c_str());
  }
  if (totalPages > 1) {
    for (int p = 0; p < totalPages && p < 5; p++) {
      int dx = 128 - totalPages * 6 + p * 6 + 2;
      if (p == g_aiPage) u8g2.drawDisc(dx, 30, 2);
      else               u8g2.drawCircle(dx, 30, 2);
    }
  }
  u8g2.setFont(u8g2_font_6x10_tr);
  u8g2.sendBuffer();
}

void displayAiResult(const String& result) {
  buildAiLines(result);
  renderAiPage();
}

void drawTextCenter(const char* text, int y) {
  int tw = u8g2.getStrWidth(text);
  int x  = (128 - tw) / 2;
  if (x < 0) x = 0;
  u8g2.setCursor(x, y);
  u8g2.print(text);
}

